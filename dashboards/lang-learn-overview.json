{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Lang-Learn – Overview: requests, CEFR score, latency, errors, tokens, pods.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"tooltip": {"mode": "single"}},
      "targets": [
        {
          "expr": "sum(rate(lang_learn_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.60},
              {"color": "green", "value": 0.75}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "avg(lang_learn_cefr_match_score)",
          "legendFormat": "Avg CEFR Score",
          "refId": "A"
        }
      ],
      "title": "Avg CEFR Match Score",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(lang_learn_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lang_learn_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(lang_learn_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 6},
      "id": 4,
      "targets": [
        {
          "expr": "rate(lang_learn_requests_total{status=\"error\"}[5m]) / rate(lang_learn_requests_total[5m]) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate %",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 6},
      "id": 5,
      "targets": [
        {
          "expr": "rate(lang_learn_tokens_generated_total[1m]) * 60",
          "legendFormat": "tokens/min",
          "refId": "A"
        }
      ],
      "title": "Tokens Generated per Minute",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 6},
      "id": 6,
      "targets": [
        {
          "expr": "lang_learn_gpu_memory_bytes",
          "legendFormat": "GPU Memory",
          "refId": "A"
        }
      ],
      "title": "GPU Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 12},
      "id": 7,
      "targets": [
        {
          "expr": "kube_pod_info{namespace=\"lang-learn\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Pod Status",
      "type": "table"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["lang-learn", "overview"],
  "title": "Lang-Learn — Overview",
  "uid": "lang-learn-overview",
  "version": 1
}
