{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Lang-Learn - Cache Performance: hit rates, misses, similarity metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.8}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "sum(rate(lang_learn_cache_requests_total{status=\"hit\"}[5m])) / sum(rate(lang_learn_cache_requests_total[5m]))",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate %",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"pieType": "pie"},
      "targets": [
        {
          "expr": "sum by (status) (rate(lang_learn_cache_requests_total[1h]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Cache Requests (Hits vs Misses)",
      "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(lang_learn_cache_similarity_bucket[5m]))",
          "legendFormat": "p95 Similarity",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(lang_learn_cache_similarity_bucket[5m]))",
          "legendFormat": "p50 Similarity",
          "refId": "B"
        }
      ],
      "title": "Cache Similarity Distribution (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "targets": [
        {
          "expr": "sum by (status) (rate(lang_learn_cache_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Cache Request Rate Over Time",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["lang-learn", "cache"],
  "title": "Lang-Learn - Cache Performance",
  "uid": "lang-learn-cache",
  "version": 1
}
